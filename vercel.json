{
  "version": 2,
  "outputDirectory": "frontend/pickit/dist",
  "builds": [
    {
      "src": "backend/api-server/src/app.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/pickit/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/api-server/src/app.ts"
    },
    {
      "source": "/(.*\\.js)",
      "destination": "frontend/pickit/$1"
    },
    {
      "source": "/(.*\\.css)",
      "destination": "frontend/pickit/$1"
    },
    {
      "source": "/(.*\\.svg)",
      "destination": "frontend/pickit/$1"
    },
    {
      "source": "/(.*\\.png)",
      "destination": "frontend/pickit/$1"
    },
    {
      "source": "/(.*\\.jpg)",
      "destination": "frontend/pickit/$1"
    },
    {
      "source": "/(.*\\.ico)",
      "destination": "frontend/pickit/$1"
    },
    {
      "source": "/(.*\\.json)",
      "destination": "frontend/pickit/$1"
    },
    {
      "source": "/(.*\\.woff2?)",
      "destination": "frontend/pickit/$1"
    },
    {
      "source": "/(.*\\.ttf)",
      "destination": "frontend/pickit/$1"
    },
    {
      "source": "/(.*\\.map)",
      "destination": "frontend/pickit/$1"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/pickit/index.html"
    }
  ]
}
